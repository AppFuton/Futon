<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	android:orientation="vertical">

	<io.github.landwarderer.futon.core.ui.sheet.AdaptiveSheetHeaderBar
		android:id="@+id/headerBar"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		app:title="@string/crash_analytics_consent_title" />

	<androidx.core.widget.NestedScrollView
		android:id="@+id/scrollView"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:clipToPadding="false">

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical"
			android:padding="@dimen/margin_normal">

			<TextView
				android:id="@+id/textView_message"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="@string/crash_analytics_consent_message"
				android:textAppearance="?textAppearanceBodyMedium" />

			<TextView
				android:id="@+id/textView_learn_more"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginTop="@dimen/margin_small"
				android:text="@string/learn_more"
				android:textAppearance="?textAppearanceBodyMedium"
				android:textColor="?colorPrimary" />

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="@dimen/margin_large"
				android:orientation="horizontal"
				android:gravity="end">

				<com.google.android.material.button.MaterialButton
					android:id="@+id/button_cancel"
					style="@style/Widget.Material3.Button.TextButton"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginEnd="@dimen/margin_small"
					android:text="@string/cancel" />

				<com.google.android.material.button.MaterialButton
					android:id="@+id/button_agree"
					style="@style/Widget.Material3.Button"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="@string/agree" />

			</LinearLayout>

		</LinearLayout>

	</androidx.core.widget.NestedScrollView>

</LinearLayout>
